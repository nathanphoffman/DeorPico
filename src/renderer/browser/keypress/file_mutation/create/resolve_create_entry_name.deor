
# Strips the "dir " prefix (if present) to get the bare entry name, and
# catches the one create/dir-specific validation case: "dir " with
# nothing after it.
unsafe_macro resolve_create_entry_name
	string entry_name = new_file_name
	if is_dir_request
		int prefix_len = len(dir_prefix)
		entry_name = s_substring(new_file_name, prefix_len, name_len)

	if is_dir_request and len(entry_name) is 0
		notice = "Directory name can't be empty"
		error = true
