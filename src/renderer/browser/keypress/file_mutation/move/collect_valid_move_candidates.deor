
# finds every file/directory matching move_query and filters out candidates
# that are already where they'd be moved to, or that the destination sits
# inside of (pulling a folder into its own descendant is filesystem-invalid).
macro collect_valid_move_candidates
	entryMatchList raw_matches = x_find_entries_matching(browse_dir, move_query)
	slash as "/"
	string dest_prefix = s_join([create_parent_dir, slash])

	entryMatchList valid_matches = empty
	for candidate in raw_matches
		(full_path) in candidate
		macro_run is_excluded_move_candidate
		if not is_excluded
			valid_matches at end = candidate
