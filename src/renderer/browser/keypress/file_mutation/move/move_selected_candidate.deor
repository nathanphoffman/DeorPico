
# Downstream of dispatch_move_candidate.deor -- resolves the single chosen
# candidate's source/destination paths, refuses to clobber an existing
# entry, then performs the move on disk.
macro_block move_selected_candidate
	macro_run resolve_move_destination
	bool already_exists = f_exists(dest_full_path)
	if already_exists
		notice = "Something with that name already exists there"
		error = true
	else
		macro_run apply_confirmed_move
