
# Downstream of confirm_move_request (see ../move_file.deor), after
# resolve_move_candidates narrows valid_matches -- routes on how many
# candidates matched.
macro_block dispatch_move_candidate
	int match_count = len(valid_matches)
	if match_count is 0
		macro_run report_no_move_match
	else if match_count > 1
		notice = "Multiple matches -- be more specific"
		error = true
	else
		macro_run move_selected_candidate
