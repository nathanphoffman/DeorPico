
fn EditorState editor_scroll(EditorState state)
	(cursor_row, scroll_row) in state
	TermSize size = xt_size()
	(rows) in size
	int view_rows = rows - 1
	if view_rows < 1
		view_rows = 1

	if cursor_row < scroll_row
		scroll_row = cursor_row
	else if cursor_row >= scroll_row + view_rows
		scroll_row = cursor_row - view_rows + 1

	new_state as state with (scroll_row)
	return new_state
