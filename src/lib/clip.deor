fn string cp_get()
	rust
		{
			match arboard::Clipboard::new() {
				Ok(mut clipboard) => clipboard.get_text().unwrap_or_default(),
				Err(_) => String::new(),
			}
		}

fn bool cp_set(string text)
	rust
		{
			match arboard::Clipboard::new() {
				Ok(mut clipboard) => clipboard.set_text(text).is_ok(),
				Err(_) => false,
			}
		}
