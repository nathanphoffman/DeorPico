
# Editing mode: text mutation -- backspace/delete/enter/typed characters
macro_block handle_text_edit
	if kind is "backspace"
		macro_run key_backspace_impl
	else if kind is "delete"
		macro_run key_delete_impl
	else if kind is "enter"
		macro_run key_enter_impl
	else if kind is "char" and chr is " " and has_selection
		macro_run key_space_comment_selection_impl
	else if kind is "char"
		macro_run key_char_impl
    else if kind is "select_all"
        macro_run key_select_all_impl